{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::ds-${environment}-downloads",
        "arn:aws:s3:::ds-${environment}-digital-files"
      ]
    },
    {
      "Sid": "AllowObjectAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::ds-${environment}-downloads/*",
        "arn:aws:s3:::ds-${environment}-digital-files/*"
      ]
    }
  ]
}
